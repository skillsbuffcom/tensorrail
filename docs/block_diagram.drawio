          <mxGeometry x="535" y="435" width="150" height="115" as="geometry" />
        </mxCell>
        <mxCell id="array" value="4 x 4 INT8 systolic array&#xa;systolic_array.v&#xa;mac_cell.v&#xa;INT8 x INT8 -&gt; INT32 accumulators&#xa;analytical peak: 256 MOPS @ 50 MHz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7e22ce;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="425" width="210" height="125" as="geometry" />
        </mxCell>
        <mxCell id="golden" value="Golden model contract&#xa;simulation/golden_model.py&#xa;expected_result.csv&#xa;4 / 4 vectors match" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="435" width="115" height="115" as="geometry" />
        </mxCell>
        <mxCell id="clock" value="U5 50 MHz oscillator&#xa;CLK_50M&#xa;no PLL in POC&#xa;timing headroom first" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=12;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="275" width="110" height="110" as="geometry" />
