<mxfile host="app.diagrams.net">
  <diagram id="tensorrail-mini" name="TensorRail-Mini System Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="TensorRail-Mini ECP5 INT8 AI Accelerator Carrier&#xa;Hardware architecture, validation flow, and review boundaries" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Proof-of-concept FPGA carrier: USB-C power-only input, monitored 1.2 V core rail, SPI boot flash, 50 MHz clock, JTAG debug, expansion I/O, RTL and SPICE validation artifacts." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="60" y="92" width="1050" height="45" as="geometry" />
        </mxCell>

        <mxCell id="carrier" value="Custom 80 x 50 mm carrier PCB boundary&#xa;2-layer FR4 prototype, KiCad 10 source, clean DRC signoff" style="swimlane;html=1;rounded=1;whiteSpace=wrap;startSize=34;fillColor=#f8fafc;strokeColor=#334155;fontSize=13;fontStyle=1;fontColor=#0f172a;swimlaneFillColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="50" y="150" width="1480" height="770" as="geometry" />
        </mxCell>

        <mxCell id="zone_power" value="Power Entry + Regulation" style="swimlane;html=1;rounded=1;whiteSpace=wrap;startSize=28;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;fontStyle=1;fontColor=#7c2d12;swimlaneFillColor=#ffedd5;" vertex="1" parent="1">
          <mxGeometry x="85" y="205" width="360" height="390" as="geometry" />
        </mxCell>
        <mxCell id="zone_fpga" value="ECP5 Module + Accelerator Datapath" style="swimlane;html=1;rounded=1;whiteSpace=wrap;startSize=28;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;fontStyle=1;fontColor=#14532d;swimlaneFillColor=#dcfce7;" vertex="1" parent="1">
          <mxGeometry x="500" y="205" width="580" height="390" as="geometry" />
        </mxCell>
        <mxCell id="zone_io" value="Configuration, Debug + Expansion" style="swimlane;html=1;rounded=1;whiteSpace=wrap;startSize=28;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=12;fontStyle=1;fontColor=#312e81;swimlaneFillColor=#e0e7ff;" vertex="1" parent="1">
