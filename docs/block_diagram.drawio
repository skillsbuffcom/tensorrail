          <mxGeometry x="85" y="635" width="1410" height="245" as="geometry" />
        </mxCell>

        <mxCell id="usb" value="J1 USB-C Receptacle&#xa;5 V sink only&#xa;CC1/CC2 Rd = 5.1 kOhm&#xa;D+/D-/SBU NC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="115" y="275" width="145" height="105" as="geometry" />
        </mxCell>
        <mxCell id="protection" value="Input protection + bulk cap&#xa;VBUS_RAW&#xa;reverse/ESD provision&#xa;test point: +5V" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=12;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="275" width="130" height="105" as="geometry" />
        </mxCell>
        <mxCell id="buck33" value="U1 TPS62130&#xa;3.3 V IO rail&#xa;feeds flash, INA219, IO&#xa;SW_3V3 / FB_3V3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=12;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="115" y="430" width="145" height="105" as="geometry" />
        </mxCell>
        <mxCell id="buck12" value="U2 TPS62130&#xa;1.2 V FPGA core rail&#xa;load-step target &lt; 100 mV&#xa;SW_1V2 / FB_1V2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=12;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="430" width="130" height="105" as="geometry" />
        </mxCell>
        <mxCell id="ina" value="U3 INA219 + shunt&#xa;monitors 1.2 V rail&#xa;I2C telemetry: SCL/SDA&#xa;VCORE_SENSED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="560" width="130" height="95" as="geometry" />
        </mxCell>

        <mxCell id="module" value="MOD1 OrangeCrab / ECP5 Feather Module&#xa;ECP5-85F fabric, onboard DDR not used by this POC&#xa;carrier exposes boot, clock, power telemetry, SPI flash, GPIO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="530" y="275" width="240" height="120" as="geometry" />
        </mxCell>
