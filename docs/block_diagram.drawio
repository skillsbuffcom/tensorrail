        <mxCell id="boot" value="Reset / Boot controls&#xa;RESET_N, BOOT_N&#xa;LED_BUSY, LED_DONE, LED_HB&#xa;bring-up visibility" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontSize=12;spacing=8;" vertex="1" parent="1">
