(kicad_pro
  (version 1)
  (generator "pcbnew")
  (generator_version "7.0")

  ;; ── Net classes ─────────────────────────────────────────────────────────────
  ;; PWR_3A  : VBUS (5 V from USB-C) and GND planes — wide tracks, large vias
  ;; PWR_1A  : 3.3 V and 1.2 V rails — medium tracks
  ;; SPI     : SPI flash and expansion-header signals
  ;; Default : General signal routing
  (net_settings
    (classes
      (net_class "Default"
        (clearance 0.2)
        (track_width 0.25)
        (via_diameter 0.8)
        (via_drill 0.4)
        (microvia_diameter 0.3)
        (microvia_drill 0.1)
        (diff_pair_width 0.2)
        (diff_pair_gap 0.25)
      )
      (net_class "PWR_1A"
        (clearance 0.2)
        (track_width 0.5)
        (via_diameter 1.0)
        (via_drill 0.5)
      )
      (net_class "PWR_3A"
        (clearance 0.3)
        (track_width 1.2)
        (via_diameter 1.2)
        (via_drill 0.6)
        (add_net "VBUS")
        (add_net "GND")
      )
      (net_class "SPI"
        (clearance 0.15)
        (track_width 0.2)
        (via_diameter 0.6)
        (via_drill 0.3)
        (add_net "SPI_SCK")
        (add_net "SPI_MOSI")
        (add_net "SPI_MISO")
        (add_net "SPI_CS_FLASH")
      )
    )
  )

  ;; ── Design rules ────────────────────────────────────────────────────────────
  ;; Minimum track/clearance for JLCPCB Standard 2-layer (2023 capabilities)
  (pcbnew
    (last_paths
      (gerbdir "gerbers")
      (gerbext ".gbr")
    )
    (page_layout_descr_file "")
  )

  (schematic
    (legacy_lib_dir "")
    (legacy_lib_list)
  )
)
