  ;; ============================================================
  ;; WIRES — local connections within each block
  ;; Only short local connections are wired; longer nets use labels.
  ;; ============================================================

  ;; J1 VBUS → D1 anode
  (wire (pts (xy 43.18 50.8) (xy 50.8 50.8))
    (stroke (width 0) (type default)) (uuid "w001"))

  ;; D1 cathode → +5V rail wire (to C1/C2 and label)
  (wire (pts (xy 55.88 50.8) (xy 57.15 50.8))
    (stroke (width 0) (type default)) (uuid "w002"))

  ;; J1 CC1 → R1 pin 1
  (wire (pts (xy 43.18 60.96) (xy 46.99 60.96))
    (stroke (width 0) (type default)) (uuid "w003"))
  ;; R1 pin 2 → GND
  (wire (pts (xy 49.53 60.96) (xy 49.53 72.39))
    (stroke (width 0) (type default)) (uuid "w004"))

  ;; J1 CC2 → R2 pin 1
  (wire (pts (xy 43.18 68.58) (xy 46.99 68.58))
    (stroke (width 0) (type default)) (uuid "w005"))
  ;; R2 pin 2 → GND (shares GND rail with R1)
  (wire (pts (xy 49.53 68.58) (xy 49.53 72.39))
    (stroke (width 0) (type default)) (uuid "w006"))

  ;; C1 top → +5V, C1 bottom → GND
